# spotseek configuration
# Copy this to .env and fill in your values to skip prompts

# Spotify API credentials (free from developer.spotify.com)
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an app (no credit card needed)
# 3. Copy Client ID and Client Secret here
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Spotify playlist URL
SPOTIFY_PLAYLIST_URL=https://open.spotify.com/playlist/...

# Audio format (flac or mp3)
PREFERRED_FORMAT=mp3

# Soulseek login
SOULSEEK_USERNAME=your_username
SOULSEEK_PASSWORD=your_password

# Where to save files
OUTPUT_DIRECTORY=

# Optional: Limit number of tracks to download (for debugging)
# Leave empty to download all tracks
MAX_TRACKS=
